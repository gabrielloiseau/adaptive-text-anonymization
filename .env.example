# Copy this file to .env and fill in the keys you need.
# The code reads keys via os.environ; it never hardcodes them.

# OpenRouter API key -- all DSPy ``dspy.LM`` instances (anonymizers, judges,
# eval backbones) are routed through OpenRouter's OpenAI-compatible API.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
